// Базовая схема для Estética в формате Prisma

model User {
  id        Int      @id
  email     String   @unique
  password  String
  name      String
  phone     String?
  addresses Json?     // Хранит список адресов
  orders    Order[]   // Связь с заказами
  isAdmin   Boolean   @default(false)
}

model Order {
  id          Int      @id
  date        String
  userEmail   String?   // Ссылка на пользователя (не строгая)
  userName    String?   // Имя для гостевых заказов
  userPhone   String?
  items       Json      // Список товаров в заказе
  total       Int
  status      String    @default("Новый")
  address     String
  comment     String?
  deliveryDate String?
  deliveryTime String?
}

model Product {
  id         Int      @id
  name       String
  price      Int
  img        String
  short_desc String?
  full_desc  String?
  cat        String   // bright, gentle, minimalism, single
}

model Promo {
  id          Int      @id
  name        String
  description String?
  category    String   // bright, gentle, all
  discount    Int
}

model Review {
  id         Int      @id
  name       String
  rating     Int
  text       String
  date       String
  approved   Boolean  @default(true)
}

model Message {
  id         Int      @id
  date       String
  name       String
  email      String
  phone      String?
  message    String
}